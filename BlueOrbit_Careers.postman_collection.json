                  "pm.test('Application fields exist', function () { const json = pm.response.json(); pm.expect(json).to.include.keys('id', 'candidate_name', 'email', 'status', 'job_id', 'resume_link'); pm.environment.set('application_id', json.id); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Applications",
          "request": {
