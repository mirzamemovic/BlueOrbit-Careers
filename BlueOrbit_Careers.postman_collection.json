                  "pm.test('Response time is acceptable', function () { pm.expect(pm.response.responseTime).to.be.below(2000); });",
                  "pm.test('Application detail includes nested job', function () { const json = pm.response.json(); pm.expect(json).to.include.keys('id', 'candidate_name', 'job'); pm.expect(json.id).to.eql(Number(pm.environment.get('application_id'))); });"
                ]
